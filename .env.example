# Copy this file to .env and replace values for your local machine.
SECRET_KEY=replace-with-a-random-secret-key
DATABASE_URL=sqlite:///FXJournal.db
MAX_UPLOAD_MB=4
FLASK_DEBUG=1
REQUIRE_EMAIL_VERIFICATION=1
# 1 blocks all new signups while keeping existing login intact.
REGISTRATION_PAUSED=0
# 1 marks new registrations approved immediately after signup; for a public launch prefer 0.
AUTO_APPROVE_NEW_USERS=0
# off | optional | required
SIGNUP_CODE_MODE=off
# Query string key used for referral links such as /register?ref=CODE123
REFERRAL_LINK_QUERY_PARAM=ref
# Comma-separated emails allowed to open the internal signup admin page.
ADMIN_USER_EMAILS=replace-with-admin@example.com
EMAIL_VERIFY_TOKEN_MAX_AGE_SECONDS=86400
PASSWORD_RESET_TOKEN_MAX_AGE_SECONDS=3600
TOKEN_SALT=replace-with-random-token-salt
PUBLIC_BASE_URL=http://localhost:5000
EMAIL_SEND_ENABLED=0
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com
# Keep real API keys only in your local .env or hosting provider secrets. Never commit them.
RESEND_API_KEY=replace-with-resend-api-key
FEEDBACK_TO_EMAIL=replace-with-your-feedback-inbox@example.com
OPENAI_API_KEY=replace-with-openai-api-key
AI_MODEL=gpt-5-mini
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_OUTPUT_TOKENS=220
# EMAIL_API_KEY=legacy-fallback-provider-api-key

# Optional overrides:
# SESSION_COOKIE_SECURE=1
# TRUST_PROXY_HEADERS=1
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# Postgres example:
# DATABASE_URL=postgresql://username:password@localhost:5432/fxjournal
